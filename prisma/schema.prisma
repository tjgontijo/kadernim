generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model EducationLevel {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String      @unique
  slug       String      @unique
  order      Int         @default(0)
  grades     Grade[]
  resources  Resource[]
  bnccSkills BnccSkill[]

  @@map("education_level")
}

model Grade {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String          @unique
  order            Int             @default(0)
  educationLevelId String          @db.Uuid
  educationLevel   EducationLevel  @relation(fields: [educationLevelId], references: [id])
  subjects         GradeSubject[]
  resources        ResourceGrade[]
  bnccSkills       BnccSkill[]

  @@index([educationLevelId])
  @@map("grade")
}

model Subject {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique
  slug String @unique
  color     String?
  textColor String?

  grades     GradeSubject[]
  resources  Resource[]
  bnccSkills BnccSkill[]

  @@map("subject")
}

model GradeSubject {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gradeId   String  @db.Uuid
  subjectId String  @db.Uuid
  grade     Grade   @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([gradeId, subjectId])
  @@index([gradeId])
  @@index([subjectId])
  @@map("grade_subject")
}

model User {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  email               String                    @unique
  phone               String?
  emailVerified       Boolean                   @default(false)
  image               String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  role                UserRole                  @default(user)
  banned              Boolean                   @default(false)
  asaasCustomerId     String?                   @unique
  asaasWalletId       String?
  accounts            Account[]
  auditLogs           BillingAuditLog[]
  invoices            Invoice[]
  sessions            Session[]
  subscription        Subscription?
  roleTitle           String?
  location            String?
  author              Author?
  curatedResources    Resource[]                @relation("ResourceCurator")
  reviews             Review[]
  reviewsAsModeration Review[]                  @relation("ReviewModerator")
  userInteractions    UserResourceInteraction[]
  relationsCreated    RelatedResource[]

  @@map("user")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId, providerId])
  @@map("account")
}

model Session {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String   @db.Uuid
  impersonatedBy       String?
  activeOrganizationId String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model Verification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String?  @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  String?

  @@map("organization")
}

model Subscription {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String                     @unique @db.Uuid
  offerId                   String?                    @db.Uuid
  asaasId                   String?                    @unique
  status                    SubscriptionStatus         @default(INACTIVE)
  paymentMethod             PaymentMethod?
  pixAutomaticAuthId        String?                    @unique
  isActive                  Boolean                    @default(false)
  purchaseDate              DateTime                   @default(now())
  expiresAt                 DateTime?
  canceledAt                DateTime?
  failureReason             SubscriptionFailureReason?
  failureCount              Int                        @default(0)
  lastFailureAt             DateTime?
  lastFailureMessage        String?
  nextRetryAt               DateTime?
  lastRetryAt               DateTime?
  failureNotificationSentAt DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  invoices                  Invoice[]
  offer                     BillingOffer?              @relation(fields: [offerId], references: [id])
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([offerId])
  @@index([asaasId])
  @@index([status])
  @@index([isActive])
  @@index([expiresAt])
  @@map("subscription")
}

model BillingPlan {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       BillingPlanCode @unique
  name       String
  cycle      BillingCycle
  accessDays Int
  isActive   Boolean         @default(true)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  offers     BillingOffer[]

  @@index([isActive])
  @@map("billing_plan")
}

model BillingOffer {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String         @unique
  planId          String         @db.Uuid
  paymentMethod   PaymentMethod
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("BRL")
  maxInstallments Int            @default(1)
  installmentRate Decimal?       @db.Decimal(6, 4)
  isActive        Boolean        @default(true)
  validFrom       DateTime       @default(now())
  validUntil      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  invoices        Invoice[]
  plan            BillingPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]

  @@index([planId])
  @@index([planId, paymentMethod, isActive])
  @@map("billing_offer")
}

model Invoice {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String        @db.Uuid
  subscriptionId    String?       @db.Uuid
  offerId           String?       @db.Uuid
  asaasId           String        @unique
  status            InvoiceStatus @default(PENDING)
  paymentMethod     PaymentMethod
  value             Float
  netValue          Float?
  description       String?
  billingType       String
  dueDate           DateTime
  paidAt            DateTime?
  refundedAt        DateTime?
  invoiceUrl        String?
  bankSlipUrl       String?
  pixQrCode         String?
  pixQrCodePayload  String?
  pixQrCodeImage    String?
  pixExpirationDate DateTime?
  pixEmailSentAt    DateTime?
  pixWhatsappSentAt DateTime?
  pixResendCount    Int           @default(0)
  pixLastResendAt   DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  offer             BillingOffer? @relation(fields: [offerId], references: [id])
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([offerId])
  @@index([asaasId])
  @@index([status])
  @@map("invoice")
}

model SplitConfig {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName     String
  cnpj            String
  walletId        String    @unique
  isActive        Boolean   @default(true)
  splitType       SplitType @default(PERCENTAGE)
  percentualValue Float?
  fixedValue      Float?
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("split_config")
}

model BillingAuditLog {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?    @db.Uuid
  actor          AuditActor @default(SYSTEM)
  action         String
  entity         String
  entityId       String
  asaasEventId   String?    @unique
  asaasPaymentId String?
  previousState  Json?
  newState       Json?
  metadata       Json?
  createdAt      DateTime   @default(now())
  user           User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([asaasEventId])
  @@map("billing_audit_log")
}

model ResourceGrade {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId String   @db.Uuid
  gradeId    String   @db.Uuid
  grade      Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, gradeId])
  @@index([resourceId])
  @@index([gradeId])
  @@map("resource_grade")
}

model ResourceImage {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId         String   @db.Uuid
  cloudinaryPublicId String   @unique
  url                String?
  alt                String?
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  resource           Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, order])
  @@map("resource_image")
}

model ResourceFile {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId         String              @db.Uuid
  name               String
  cloudinaryPublicId String   @unique
  url                String?
  fileType           String?
  sizeBytes          Int?
  createdAt          DateTime            @default(now())
  resource           Resource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  images             ResourceFileImage[]

  @@index([resourceId])
  @@map("resource_file")
}

model ResourceFileImage {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId             String       @db.Uuid
  cloudinaryPublicId String   @unique
  url                String?
  alt                String?
  order              Int          @default(0)
  createdAt          DateTime     @default(now())
  file               ResourceFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId, order])
  @@map("resource_file_image")
}

model ResourceVideo {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId         String   @db.Uuid
  title              String
  cloudinaryPublicId String   @unique
  url                String?
  thumbnail          String?
  duration           Int?
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  resource           Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, order])
  @@map("resource_video")
}


model Resource {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String?
  educationLevelId String    @db.Uuid
  subjectId        String    @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  originRequestId  String?   @unique
  authorId         String?   @db.Uuid
  author           Author?   @relation("authorCreated", fields: [authorId], references: [id], onDelete: SetNull)
  isCurated        Boolean   @default(false)
  curatedAt        DateTime?
  curatorId        String?   @db.Uuid
  curator          User?     @relation("ResourceCurator", fields: [curatorId], references: [id], onDelete: SetNull)

  resourceType             ResourceType @default(OTHER)
  pagesCount               Int?
  estimatedDurationMinutes Int?
  slug                     String?      @unique

  reviewCount   Int   @default(0)
  averageRating Float @default(0)
  downloadCount Int   @default(0)

  thumbUrl       String?
  thumbPublicId  String?

  googleDriveUrl String?
  externalId     Int?      @unique

  archivedAt DateTime?

  reviews          Review[]
  userInteractions UserResourceInteraction[]
  sourceRelations  RelatedResource[]         @relation("source")
  targetRelations  RelatedResource[]         @relation("target")

  educationLevel EducationLevel       @relation(fields: [educationLevelId], references: [id])
  subject        Subject              @relation(fields: [subjectId], references: [id])
  files          ResourceFile[]
  grades         ResourceGrade[]
  images         ResourceImage[]
  videos         ResourceVideo[]
  bnccSkills     ResourceBnccSkill[]
  objectives    ResourceObjective[]
  steps         ResourceStep[]

  @@index([educationLevelId])
  @@index([subjectId])
  @@index([authorId])
  @@index([curatorId])
  @@index([title, id])
  @@index([slug])
  @@index([archivedAt])
  @@map("resource")
}

model ResourceObjective {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId String   @map("resource_id") @db.Uuid
  text       String
  order      Int      @default(0)
  createdAt  DateTime @map("created_at") @default(now())
  updatedAt  DateTime @map("updated_at") @updatedAt
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, order])
  @@map("resource_objective")
}

model ResourceStep {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId String   @map("resource_id") @db.Uuid
  type       String
  title      String
  duration   String?
  content    String   @db.Text
  order      Int      @default(0)
  createdAt  DateTime @map("created_at") @default(now())
  updatedAt  DateTime @map("updated_at") @updatedAt
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, order])
  @@map("resource_step")
}

model BnccSkill {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String

  educationLevelId String         @db.Uuid
  educationLevel   EducationLevel @relation(fields: [educationLevelId], references: [id])

  gradeId String? @db.Uuid
  grade   Grade?  @relation(fields: [gradeId], references: [id])

  subjectId String?  @db.Uuid
  subject   Subject? @relation(fields: [subjectId], references: [id])

  unitTheme             String?
  knowledgeObject       String?
  description           String  @db.Text
  comments              String? @db.Text
  curriculumSuggestions String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources ResourceBnccSkill[]

  @@unique([code, gradeId], name: "code_gradeId")
  @@index([educationLevelId])
  @@index([gradeId])
  @@index([subjectId])
  @@index([code])
  @@map("bncc_skill")
}

model ResourceBnccSkill {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId  String    @db.Uuid
  resource    Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  bnccSkillId String    @db.Uuid
  bnccSkill   BnccSkill @relation(fields: [bnccSkillId], references: [id], onDelete: Cascade)

  @@unique([resourceId, bnccSkillId])
  @@index([resourceId])
  @@index([bnccSkillId])
  @@map("resource_bncc_skill")
}

enum UserRole {
  user
  subscriber
  editor
  manager
  admin
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  OVERDUE
  CANCELED
  EXPIRED
  FAILED
}

enum SubscriptionFailureReason {
  EXPIRED
  DENIED
  CANCELED_BY_USER
  FAILED_DEBIT
  OTHER
}

enum InvoiceStatus {
  PENDING
  CONFIRMED
  RECEIVED
  OVERDUE
  REFUNDED
  REFUND_REQUESTED
  CHARGEBACK_REQUESTED
  CHARGEBACK_DISPUTE
  AWAITING_CHARGEBACK_REVERSAL
  DUNNING_REQUESTED
  DUNNING_RECEIVED
  AWAITING_RISK_ANALYSIS
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
  PIX_AUTOMATIC
  BOLETO
}

enum BillingPlanCode {
  monthly
  annual
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SplitType {
  PERCENTAGE
  FIXED
}

enum AuditActor {
  USER
  ADMIN
  SYSTEM
}

enum ConfigType {
  string
  number
  boolean
  json
}

model Author {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  displayName String
  displayRole String?
  location    String?
  verified    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources Resource[] @relation("authorCreated")

  @@index([displayName])
  @@map("author")
}

model Review {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId String @db.Uuid
  userId     String @db.Uuid

  rating  Int     @db.SmallInt
  comment String? @db.Text

  status      ReviewStatus @default(PENDING)
  moderatedAt DateTime?
  moderatedBy String?      @db.Uuid

  helpfulCount   Int @default(0)
  unhelpfulCount Int @default(0)
  flagCount      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resource  Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderator User?    @relation("ReviewModerator", fields: [moderatedBy], references: [id], onDelete: SetNull)

  @@unique([resourceId, userId])
  @@index([resourceId, status])
  @@index([userId, status])
  @@index([createdAt])
  @@map("review")
}

model UserResourceInteraction {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId     String @db.Uuid
  resourceId String @db.Uuid

  isSaved Boolean   @default(false)
  savedAt DateTime?

  isPlanned  Boolean   @default(false)
  plannedFor DateTime?

  hasDownloaded Boolean   @default(false)
  downloadedAt  DateTime?
  downloadCount Int       @default(0)

  hasReviewed Boolean @default(false)
  reviewId    String? @unique @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId, isSaved])
  @@index([userId, isPlanned, plannedFor])
  @@index([userId, hasDownloaded])
  @@index([resourceId])
  @@map("user_resource_interaction")
}

model RelatedResource {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  sourceResourceId String @db.Uuid
  targetResourceId String @db.Uuid

  relationType   RelatedResourceType @default(COMPLEMENTS)
  relevanceScore Int                 @default(3) @db.SmallInt

  createdBy String   @db.Uuid
  createdAt DateTime @default(now())

  source  Resource @relation("source", fields: [sourceResourceId], references: [id], onDelete: Cascade)
  target  Resource @relation("target", fields: [targetResourceId], references: [id], onDelete: Cascade)
  creator User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@unique([sourceResourceId, targetResourceId])
  @@index([sourceResourceId])
  @@index([targetResourceId, relationType])
  @@map("related_resource")
}

enum ResourceStepType {
  WARMUP
  DISTRIBUTION
  PRACTICE
  CONCLUSION
  DISCUSSION
  ACTIVITY
  REFLECTION
}

enum ResourceType {
  PRINTABLE_ACTIVITY
  LESSON_PLAN
  GAME
  ASSESSMENT
  OTHER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum RelatedResourceType {
  COMPLEMENTS
  PREREQUISITE
  ADVANCED
  RELATED_TOPIC
}
